# ══════════════════════════════════════════════════════════════════════════════
# AI-CAM-RFQ Platform — Environment Variables
# Copy this to .env and fill in real values
# ══════════════════════════════════════════════════════════════════════════════

# ── General ───────────────────────────────────────────────────────────────────
PROJECT_NAME=AI-CAM-RFQ Platform
ENV=development
DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mechai
DATABASE_ECHO=false

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=dev-secret-change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── GCP (leave empty for local dev) ──────────────────────────────────────────
GCP_PROJECT_ID=
GCS_BUCKET_NAME=mechai-cad-uploads
PUBSUB_TOPIC=cad-processing
PUBSUB_SUBSCRIPTION=cad-processing-sub

# ── Service URLs ──────────────────────────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:8001
CAD_SERVICE_URL=http://localhost:8002
AI_SERVICE_URL=http://localhost:8003

# ── LLM (plan optimiser) ──────────────────────────────────────────────────────
# Provider: openai | anthropic | google | openrouter | ollama | none
LLM_PROVIDER=google
LLM_MODEL=gemini-2.5-flash-lite
LLM_API_KEY=AIzaSyDXK6s4ssb7Dhp0TOjv8oY_4O_6lXTGtl8
LLM_BASE_URL=
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
OLLAMA_HOST=http://localhost:11434

# ── AI Service ────────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8003

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173"]
